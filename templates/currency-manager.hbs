<form class="currency-manager" autocomplete="off">

  <p class="notes hint">
    Add up to {{maxSlots}} custom currency slots. Click an icon to change it.
    The <strong>colour wheel</strong> next to each icon shifts its hue — useful for recolouring the default gold coin.
    <strong>GP Value</strong> = worth of 1 coin in GP (wealth total display only; 0 to exclude).
    <strong>Converts Into</strong> + <strong>Rate</strong> = conversion chain when Convert Currency is clicked.
  </p>

  {{#if currencies.length}}
  <table class="currency-manager-table">
    <thead>
      <tr>
        <th class="col-icon">Icon</th>
        <th class="col-name">Name</th>
        <th class="col-abrv">Abbr.</th>
        <th class="col-rate">GP Value</th>
        <th class="col-vis">Visibility</th>
        <th class="col-converts-to">Converts Into</th>
        <th class="col-convert-rate">Rate</th>
        <th class="col-del"></th>
      </tr>
    </thead>
    <tbody>
      {{#each currencies}}
      <tr data-id="{{id}}">

        <td class="col-icon currency-icon-cell">
          {{!-- data-src holds the relative path; .src gives an absolute URL --}}
          <img class="currency-icon-img"
               src="{{img}}"
               data-src="{{img}}"
               data-id="{{id}}"
               title="Click to change icon">
          <input type="color"
                 name="{{id}}.tintColor"
                 class="currency-tint-input"
                 value="{{tintColorInput}}"
                 title="Shift the icon hue (colour tint)">
        </td>

        <td class="col-name">
          <input type="text" name="{{id}}.name" value="{{name}}" placeholder="Name" required>
        </td>

        <td class="col-abrv">
          <input type="text" name="{{id}}.abbreviation" value="{{abbreviation}}" placeholder="GP" maxlength="6">
        </td>

        <td class="col-rate">
          <input type="number" name="{{id}}.exchangeRate" value="{{exchangeRate}}"
                 step="0.0001" min="0" placeholder="0"
                 title="GP value of 1 coin — used only for the wealth total display">
        </td>

        <td class="col-vis">
          <select name="{{id}}.visibility">
            <option value="always" {{#if visAlways}}selected{{/if}}>Always Visible</option>
            <option value="owned"  {{#if visOwned}}selected{{/if}}>Visible if Non-Zero</option>
            <option value="never"  {{#if visNever}}selected{{/if}}>Never Visible</option>
          </select>
        </td>

        <td class="col-converts-to">
          <select name="{{id}}.convertsTo" class="converts-to-select" data-id="{{id}}">
            {{#each convertOptions}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </td>

        <td class="col-convert-rate">
          <input type="number" name="{{id}}.convertRate" value="{{convertRate}}"
                 min="1" step="1" placeholder="1"
                 title="How many of this coin = 1 of the target currency">
        </td>

        <td class="col-del">
          <a class="currency-remove-btn" data-id="{{id}}" title="Remove this currency slot">
            <i class="fas fa-trash"></i>
          </a>
        </td>

      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <p class="notification info">No custom currencies configured yet.</p>
  {{/if}}

  <div class="currency-manager-footer flexrow">
    {{#if canAdd}}
    <button type="button" class="currency-add-btn">
      <i class="fas fa-plus"></i> Add Currency
    </button>
    {{else}}
    <span class="notification warn" style="flex:1">Maximum of {{maxSlots}} slots reached.</span>
    {{/if}}

    <button type="submit" class="save-btn">
      <i class="fas fa-save"></i> Save
    </button>
  </div>

</form>
